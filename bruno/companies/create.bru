    "headOffice": "Cotonou, Bénin",
    "email": "contact@masociete.com",
    "phonePrimary": "+229 97 00 00 00",
    "phoneSecondary": "+229 97 11 11 11",
    "website": "https://masociete.com",
    "rccm": "RB/COT/24/A/12345",
    "ifu": "1234567890123",
    "legalStatus": "SARL",
    "bankAccountNumber": "BJ063 01001 000123456789 10"
  }
}
