meta {
  name: Create Company
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/companies
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Ma Société",
    "profile": "SERVICE_PROVIDER",
